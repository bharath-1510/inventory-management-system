# .gitignore for Java Maven project
# Compiled class files
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*

# Maven
/target/
!.mvn/wrapper/maven-wrapper.jar

# Eclipse
.project
.classpath
.csettings
.settings/
/bin/

# IntelliJ IDEA
*.iml
.idea/
out/

# VS Code
.vscode/

# OS generated files
.DS_Store
Thumbs.db

# Environment files
.env
